generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model chat_message {
  msg_id       String       @id @default(dbgenerated("replace((gen_random_uuid())::text, '-'::text, ''::text)")) @db.Char(32)
  chat_id      String       @db.Char(32)
  role         String       @db.VarChar(10)
  content      String
  create_time  DateTime     @default(now())
  chat_session chat_session @relation(fields: [chat_id], references: [chat_id], onDelete: Cascade)

  @@index([chat_id], map: "idx_chatid")
}

model chat_session {
  chat_id      String         @id @default(dbgenerated("replace((gen_random_uuid())::text, '-'::text, ''::text)")) @db.Char(32)
  user_id      BigInt
  title        String         @default("") @db.VarChar(255)
  create_time  DateTime       @default(now())
  update_time  DateTime       @default(now())
  is_delete    Boolean        @default(false)
  chat_message chat_message[]
  sys_user     sys_user       @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, is_delete], map: "idx_userid")
}

model sys_user {
  id           BigInt         @id @default(autoincrement())
  username     String         @unique @db.VarChar(50)
  password     String         @db.VarChar(100)
  chat_session chat_session[]
}
